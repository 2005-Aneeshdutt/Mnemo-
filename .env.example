GROQ_API_KEY=your_key_here

# Chat / extraction
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_EXTRACT_MODEL=llama-3.1-8b-instant

# Embeddings: primary + comma-separated fallbacks (tried in order)
# GROQ_EMBED_MODEL=nomic-embed-text-v1_5
# GROQ_EMBED_MODEL_FALLBACKS=

# Legacy MEMORI_* names still work if MNEMO_* is unset.

# MNEMO_NO_EMBEDDINGS=0

# Hybrid retrieval weights
# MNEMO_W_DENSE=0.5
# MNEMO_W_LEX=0.35
# MNEMO_W_REC=0.15

# FAISS ANN prefilter
# MNEMO_ANN_ENABLED=1
# MNEMO_ANN_MIN_ROWS=32
# MNEMO_ANN_CANDIDATE_MULT=8
# MNEMO_ANN_MIN_CANDIDATES=64
# MNEMO_ANN_MAX_CANDIDATES=512

# MNEMO_TOP_K=12
# MNEMO_RECENT_MSG=12
# MNEMO_DB_PATH=data/memory.db

# Public API auth (optional)
# MNEMO_API_KEY=generate_a_long_random_secret
# MNEMO_RATE_LIMIT=120/minute
# MNEMO_RATE_LIMIT_CHAT=60/minute

# HTTP API
# MNEMO_API_HOST=127.0.0.1
# MNEMO_API_PORT=8765
